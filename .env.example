# Copy to .env and fill values locally. Only KEY NAMES are committed — never values.

# Path to the GCP service-account JSON used for Vertex AI (Gemini) auth.
GOOGLE_APPLICATION_CREDENTIALS=configs/bq_creds.json

# Vertex AI region. project_id is read from the service-account file.
VERTEX_LOCATION=us-central1

# Optional: path to the app config (defaults to configs/config.yaml).
BRAHMA_CONFIG=configs/config.yaml
